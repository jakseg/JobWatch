# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Encryption key for the SQLite database (generate a random string)
DB_ENCRYPTION_KEY=your-encryption-key-here

# Google Custom Search API (optional — enables career page auto-search)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CSE_API_KEY=
# Create at: https://programmablesearchengine.google.com/
GOOGLE_CSE_CX=
